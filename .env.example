KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_LOCATION_ID=
# For multiple stores, use comma-separated IDs, for example: 12345678,87654321
MOCK_KROGER=0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OUTPUT_MODE=todoist,email
TODOIST_API_TOKEN=
TODOIST_API_BASE_URL=https://api.todoist.com/api/v1
TODOIST_PROJECT_NAME=Weekly Deals
# email adapter only (optional digest emails):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                       # your email; also the "From:" sender unless EMAIL_FROM is set
SMTP_PASS=                       # Google app password (16 chars, spaces OK) - not your login password
NOTIFY_EMAIL=                    # recipient (can be the same as SMTP_USER or different)
EMAIL_FROM=
TZ=America/New_York
RUN_DAY=wed
RUN_HOUR=7
WATCHLIST_PATH=/data/watchlist.yaml
DATABASE_URL=sqlite:////data/app.db
PUID=1000
PGID=1000
