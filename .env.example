KROGER_CLIENT_ID=
KROGER_CLIENT_SECRET=
KROGER_LOCATION_ID=
# For multiple stores, use comma-separated IDs, for example: 12345678,87654321
MOCK_KROGER=0
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3.5-flash
OUTPUT_MODE=todoist,email
TODOIST_API_TOKEN=
TODOIST_API_BASE_URL=https://api.todoist.com/api/v1
TODOIST_PROJECT_NAME=Weekly Deals
# email adapter only (optional digest emails):
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=                       # your email; also the "From:" sender unless EMAIL_FROM is set
SMTP_PASS=                       # Google app password (16 chars, spaces OK) - not your login password
NOTIFY_EMAIL=                    # recipient (can be the same as SMTP_USER or different)
EMAIL_FROM=
TZ=America/New_York
RUN_DAY=wed,fri
RUN_HOUR=0
RUN_MINUTE=30
# Jobs run every Wednesday and Friday at 00:30 (your timezone). Kroger drops new ads Wednesday
# at midnight (week-long sales); many regions also run 3-day Friday-Sunday specials that appear
# by Friday morning. Running twice catches both. RUN_DAY accepts comma-separated day
# abbreviations (mon/tue/wed/thu/fri/sat/sun). Adjust RUN_HOUR/RUN_MINUTE to suit your routine
# (e.g., 06:00 for pre-breakfast review).
WATCHLIST_PATH=/data/watchlist.yaml
DATABASE_URL=sqlite:////data/app.db
PUID=1000
PGID=1000
